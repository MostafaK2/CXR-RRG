# ─────────────────────────────────────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg
pip-wheel-metadata/

# ─────────────────────────────────────────────────────────────────────────────
# Virtual environments
# ─────────────────────────────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/
proj_venv/
*.venv

# ─────────────────────────────────────────────────────────────────────────────
# Jupyter
# ─────────────────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ─────────────────────────────────────────────────────────────────────────────
# Dataset files — never commit raw data
# ─────────────────────────────────────────────────────────────────────────────
*.csv
*.json
*.jsonl
*.h5
*.hdf5
*.npy
*.npz
*.pkl
*.pickle
*.parquet
*.feather
*.tsv

# Except tracked config/schema files
!configs/**/*.yml
!configs/**/*.yaml

# ─────────────────────────────────────────────────────────────────────────────
# Images and medical data
# ─────────────────────────────────────────────────────────────────────────────
*.dcm
*.jpg
*.jpeg
*.tiff
*.tif
*.bmp
*.gif

# ─────────────────────────────────────────────────────────────────────────────
# Model weights and checkpoints — usually too large for git
# ─────────────────────────────────────────────────────────────────────────────
*.pt
*.pth
*.bin
*.ckpt
*.safetensors
*.onnx
checkpoints/
saved_models/
weights/
outputs/

# ─────────────────────────────────────────────────────────────────────────────
# Tokenizer artefacts — regenerated at runtime
# ─────────────────────────────────────────────────────────────────────────────
bpe_tokenizer.json
tokenizer.json
vocab.txt
merges.txt

# ─────────────────────────────────────────────────────────────────────────────
# Logs
# ─────────────────────────────────────────────────────────────────────────────
logs/
*.log
*.log.*
log_*/
wandb/
runs/
tensorboard/
lightning_logs/

# ─────────────────────────────────────────────────────────────────────────────
# Experiment tracking
# ─────────────────────────────────────────────────────────────────────────────
mlruns/
.mlflow/
.neptune/
ray_results/

# ─────────────────────────────────────────────────────────────────────────────
# IDE and editor
# ─────────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
.directory

# ─────────────────────────────────────────────────────────────────────────────
# Environment and secrets — never commit
# ─────────────────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
secrets.yml
secrets.yaml
api_keys.txt
*.key

# ─────────────────────────────────────────────────────────────────────────────
# HuggingFace cache
# ─────────────────────────────────────────────────────────────────────────────
.cache/
~/.cache/huggingface/
hub/

# ─────────────────────────────────────────────────────────────────────────────
# CheXbert source — cloned separately, not part of this repo
# ─────────────────────────────────────────────────────────────────────────────
CheXbert/
chexbert/

# ─────────────────────────────────────────────────────────────────────────────
# Misc artefacts
# ─────────────────────────────────────────────────────────────────────────────
*.tmp
*.temp
*.bak
*.orig
.hypothesis/
.pytest_cache/
.mypy_cache/
.ruff_cache/
profile_output/
*.prof
